{
  "entities": {
    "profiles": {
      "title": "User Profiles",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User ID from Supabase Auth" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "memory": {
      "title": "Chat Memory",
      "description": "Stores chat history for each user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string", "description": "Reference to profiles.id" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "role", "content"]
    },
    "goals": {
      "title": "User Goals",
      "description": "Stores user goals for planning.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "title"]
    }
  }
}
